# G:\Dx is a hub repository. Child folders are independent repositories,
# archives, runtime state, or pinned tools and must not be absorbed here.

/*

!/.gitattributes
!/.gitignore
!/.rgignore
!/.github/
!/.github/workflows/
!/.dx/
!/AGENTS.md
!/CHANGELOG.md
!/CURRENT_STATUS.md
!/DX.md
!/DX_LANE_PASS_SYSTEM.md
!/DX_MANAGER_MEMORY.md
!/PLAN.md
!/README.md
!/TODO.md
!/docs/
!/docs/policies/
!/docs/superpowers/
!/docs/superpowers/plans/
!/dx
!/scripts/

/.dx/*
!/.dx/launch-workspace.toml
trash/
**/target/
**/node_modules/
**/.next/
**/dist/
**/build/
**/.tmp/
**/*.pdb
**/*.exe
**/*.dll
